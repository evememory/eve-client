{
  "pack": "PACK-12",
  "artifact": "channel-smoke-plan-template",
  "schema_version": 1,
  "channel": "windsurf",
  "install_source": "windsurf",
  "proof_scope": "actual_host_smoke",
  "promotion_ready": false,
  "operator_required": true,
  "runner": "packages/client/scripts/run_pack12_channel_smoke.py",
  "matrix_artifact": "docs/specs/artifacts/pack12-remaining-channel-smoke-matrix-2026-06-17.json",
  "evidence_artifact_template": "docs/specs/artifacts/pack12-windsurf-host-smoke-{timestamp}.json",
  "not_promoted": ["Template only; actual Windsurf registry-provider smoke evidence has not been produced."],
  "steps": {
    "clean_environment": {"purpose": "Prove a clean Windsurf profile/workspace.", "command_template": ["operator-run", "Create clean Windsurf profile and confirm no Eve MCP config."], "required_env": ["EVE_PACK12_CLEAN_PROFILE"], "must_contain": ["clean_environment"], "timeout_seconds": 120},
    "entry_url": {"purpose": "Prove Windsurf channel attribution.", "command_template": ["operator-run", "Open Windsurf channel docs/listing path and confirm install_source=windsurf."], "required_env": ["EVE_PACK12_TARGET"], "must_contain": ["install_source=windsurf"], "timeout_seconds": 120},
    "install_or_import": {"purpose": "Apply Eve MCP config through the Windsurf provider path.", "command_template": ["operator-run", "Run Eve client Windsurf install/apply from a clean profile and confirm eve-memory config."], "required_env": ["EVE_PACK12_CLEAN_PROFILE"], "must_contain": ["eve-memory"], "timeout_seconds": 300},
    "connect": {"purpose": "Connect Windsurf to Eve MCP.", "command_template": ["operator-run", "Complete Windsurf MCP auth/connect and verify connectivity."], "required_env": ["EVE_PACK12_TARGET"], "must_contain": ["windsurf", "connected"], "timeout_seconds": 300},
    "store": {"purpose": "Store a smoke memory from Windsurf.", "command_template": ["operator-run", "Use Windsurf Eve MCP to store ${EVE_PACK12_SMOKE_ID}."], "required_env": ["EVE_PACK12_SMOKE_ID"], "must_contain": ["memory_store", "success"], "timeout_seconds": 180},
    "read": {"purpose": "Read the smoke memory from Windsurf.", "command_template": ["operator-run", "Use Windsurf Eve MCP to read ${EVE_PACK12_SMOKE_ID}."], "required_env": ["EVE_PACK12_SMOKE_ID"], "must_contain": ["memory_read", "EVE_PACK12_SMOKE_ID"], "timeout_seconds": 180},
    "forget": {"purpose": "Forget the smoke memory from Windsurf.", "command_template": ["operator-run", "Use Windsurf Eve MCP to forget ${EVE_PACK12_SMOKE_ID}."], "required_env": ["EVE_PACK12_SMOKE_ID"], "must_contain": ["memory_forget", "success"], "timeout_seconds": 180},
    "install_source_flow": {"purpose": "Prove windsurf attribution.", "command_template": ["operator-run", "Verify install_source=windsurf in local/server evidence."], "required_env": ["EVE_PACK12_TARGET"], "must_contain": ["install_source=windsurf"], "timeout_seconds": 180},
    "connector_install_completed": {"purpose": "Exercise connector.install.completed for windsurf.", "command_template": ["operator-run", "Trigger and verify connector.install.completed for windsurf."], "required_env": ["EVE_PACK12_TARGET"], "must_contain": ["connector.install.completed", "windsurf"], "timeout_seconds": 180},
    "rollback_or_uninstall": {"purpose": "Rollback Windsurf config.", "command_template": ["operator-run", "Remove Eve MCP from Windsurf and verify config is absent."], "required_env": ["EVE_PACK12_CLEAN_PROFILE"], "must_contain": ["rollback", "success"], "timeout_seconds": 300}
  }
}
